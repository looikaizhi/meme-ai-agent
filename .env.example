# ============================================================================
# MemeDog Radar — 环境变量模板
# 用法:把本文件复制为 .env(同目录,即项目根),再填入真实值。
#   cp .env.example .env
# .env 已在 .gitignore 中,不会入库。
# 变量名大小写不敏感(pydantic-settings),写大写即可。
# 留空 / 用 # 注释掉的项 = 该功能自动降级(系统不会崩)。
# ============================================================================

# --- 链上持币 / 聪明钱(Helius) -------------------------------------------
# 需要。缺失则“持币分布/聪明钱”维度降级为不可用。
# 申请:https://dashboard.helius.dev → 注册 → API Keys → Generate(免费层 10万 credits/月)
HELIUS_API_KEY=

# --- GMGN OpenAPI(memedogV2:安全/持仓/流动性/聪明钱统一数据源) -----------
# memedogV2 用 gmgn-cli 接管 RugCheck + Helius 的活。
# 申请:https://gmgn.ai/ai → 注册 → API Keys。读数据只需 GMGN_API_KEY。
# 频率限制紧(~1 req/s 起,429 会封 5min),客户端已带限速/缓存/退避。
GMGN_API_KEY=

# --- 安全 / Rug(RugCheck) -------------------------------------------------
# 【memedogV2 已弃用,改用 GMGN】保留仅兼容旧 memedog 路径。
# 公开 API,当前免 key 可用,通常留空即可。
# RUGCHECK_API_KEY=

# --- 社交热度(Twitter / X) ----------------------------------------------
# 【已弃用,Phase 1 起 Twitter 已移出生产路径】保留仅为兼容旧配置,可不填。
# 社交信号现由:DexScreener 免费社交元数据 + 确定性叙事分类 承接。
# TWITTER_BEARER=

# --- LLM 裁决(本实验默认:Codex CLI) ------------------------------------
# 默认走 Codex CLI 子进程(模型串 codex:default),**不在这里放 key**!
# 它用你的 ChatGPT 订阅,认证靠一次性 `codex login`(token 存 ~/.codex/auth.json)。
# 安装:npm i -g @openai/codex   然后:codex login(浏览器登录 ChatGPT 账户)
#
# 仅当你把 llmjudge 模型改成 litellm:<provider>/<model> 做对比时,才填下面对应一项:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=

# --- 告警(Telegram,可选) -----------------------------------------------
# 缺任一则告警静默跳过(系统不崩)。
# 1) 在 Telegram 找 @BotFather → /newbot → 拿到 bot token
# 2) chat id:把 bot 拉进目标对话,或找 @userinfobot 获取你的数字 id
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Bitget GetAgent / Playbook hosted backtest(可选) -----------------------
# 用于 `scripts/run_playbook_backtest.py` 上传 Playbook package 并触发官方云端回测。
# 这个值会作为 HTTP `ACCESS-KEY` header 发送到 https://api.bitget.com。
# BITGET_PLAYBOOK_ACCESS_KEY=
# 兼容别名: PLAYBOOK_API_KEY / BITGET_API_KEY / BITGET_ACCESS_KEY
